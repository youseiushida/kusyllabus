          "cookies": [],
          "content": {
            "size": 53282,
            "mimeType": "text/html",
            "compression": -53,
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n  <head>\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-31j\" />\r\n    <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/behavior.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/layout.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/la_style.css\">\r\n    <script type=\"text/javascript\" src=\"/js/prototype.js\"> </script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery-2.1.4.js\"> </script>\r\n    <script>\r\n     jQuery.noConflict();\r\n    </script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery_auto.js\"> </script>\r\n\r\n    <title>京都大学教務情報システム</title>\r\n  <link rel=\"stylesheet\" href=\"/css/webfont.css\" />\r\n\r\n<style>\r\n  .css-submit-button {\r\n    display: inline-block;\r\n  }\r\n  input::-webkit-contacts-auto-fill-button {\r\n    visibility: hidden;\r\n    display: none !important;\r\n    pointer-events: none;\r\n    position: absolute;\r\n    right: 0;\r\n  }\r\n</style>\r\n\r\n<script type=\"text/javascript\">\r\n  jQuery(function() {\r\n    jQuery(\".css-submit-button\").click(function(e) {\r\n      jQuery(e.target).parents(\"form\").submit();\r\n    });\r\n  });\r\n</script>\r\n</head>\r\n  <body onload=\"\">\r\n  <div id=\"frame\">\r\n    <div id=\"header\">\n  <div class=\"header_left\">\n    <img src=\"/img/zk_logo_l.gif\" alt=\"TOPへ\"  id=\"id_img_10_0\" >\n  </div>\n\n  <div class=\"header_right\">\n    <div class=\"logo\"><img src=\"/img/zk_logo_r.gif\" alt=\"\" id=\"id_img_10_1\" ></div>\n\n    <div class=\"header_menu\">\n      <ul class=\"header_menu_left\">      \n      </ul>\n\n      <ul class=\"header_menu_right three_storied\">\n        <li style=\"height: 24px\">&nbsp;</li>\n        <li style=\"height: 24px\"><a href=\"/external/open_syllabus/top\" id=\"id_a_10_6\" ><img src=\"/img/zk_header_home_o.gif\" alt=\"KULASIS TOP\" /></a></li>\n      </ul>\n    </div>\n\n  </div>\n</div>\n<div id=\"wrapper\">\r\n      <div class=\"contents\" style=\"width: 968px\">\r\n        <div class=\"right\" style=\"margin-top: 3px;\">\r\n          <span class=\"link\"><a href=\"/external/open_syllabus/search?condition.departmentNo=80&condition.openSyllabusTitle=&condition.openSyllabusTitleEn=&condition.courseNumberingJugyokeitaiNo=&condition.courseNumberingLanguageNo=&condition.semesterNo=&condition.courseNumberingLevelNo=&condition.courseNumberingBunkaNo=&condition.teacherName=&condition.teacherNameEn=&condition.keyword=&condition.keywordEn=&condition.syutyu=false&page=2&display_lang=en\">English</a></span> |\r\n          <span class=\"link\"><a href=\"/external/open_syllabus/search?condition.departmentNo=80&condition.openSyllabusTitle=&condition.openSyllabusTitleEn=&condition.courseNumberingJugyokeitaiNo=&condition.courseNumberingLanguageNo=&condition.semesterNo=&condition.courseNumberingLevelNo=&condition.courseNumberingBunkaNo=&condition.teacherName=&condition.teacherNameEn=&condition.keyword=&condition.keywordEn=&condition.syutyu=false&page=2&display_lang=jp\">日本語</a></span>\r\n        </div>\r\n\r\n        <!-- contents -->\r\n\r\n        <!-- title -->\r\n  <div class=\"title\">\r\n    <div style=\"font-family: 'KulasisWebFont'; font-weight: bold; color: #020C4A; font-size: 24px;\">\r\n      <img src=\"/img/mark_01.gif\" alt=\"\" id=\"id_img_1239_0\">\r\n      Find Syllabus\r\n    </div>\r\n  </div>\r\n\r\n  <!-- +++++++++++++++++++++ contents +++++++++++++++++++++ -->\r\n\r\n  <br />\r\n  <center >\r\n\r\n    <script type=\"text/javascript\">\r\nfunction clearCourseSearchForm() {\r\n    jQuery('#week_schedule_holder input').each(function(){\r\n    \tthis.checked = false;\r\n    });\r\n\r\n    jQuery(\"#select_departmentNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_openSyllabusTitle\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_courseNumberingJugyokeitaiNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_courseNumberingLanguageNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_semesterNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_courseNumberingLevelNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#select_courseNumberingBunkaNo\")[0].selectedIndex = 0;\r\n    jQuery(\"#teacher_name\")[0].value = '';\r\n    jQuery(\"#keyword\")[0].value = '';\r\n}\r\n\r\nfunction checkAllDays() {\r\n\t\r\n    var inputs = jQuery('#week_schedule_holder input').filter(function(){return jQuery(this).attr('name') != 'condition.syutyu'; });\r\n    \r\n    var all = true;\r\n    inputs.each(function(){\r\n    \tif (!this.checked) {\r\n    \t\tall = false;\r\n\t\t}\r\n    });\r\n    \r\n    if (all) {\r\n    \tinputs.each(function(){this.checked = false;});\r\n    } else {\r\n    \tinputs.each(function(){this.checked = true;});\r\n\t}\r\n}\r\n\r\njQuery(function() {\r\n    jQuery(\"#select_departmentNo\").bind(\"change\", function() {\r\n        jQuery.get(\r\n            \"open_syllabus_titles\",\r\n            {departmentNo: jQuery(\"#select_departmentNo\").val()},\r\n            function(data) {\r\n                jQuery(\"#select_openSyllabusTitle\").html(data);\r\n                setTimeout(function() {\r\n                    jQuery(\"#select_openSyllabusTitle\")[0].selectedIndex = 0;\r\n                }, 0);\r\n            }\r\n        );\r\n    });\r\n});\r\n</script>\r\n<form action=\"search\" method=\"get\" name=\"detail_search\" id=\"id_form_1370_0\" >\r\n  <table class=\"form_table\" style=\"width: 570\" >\r\n    <tr>\r\n      <td style=\"text-align: right;\" colspan=\"4\">\r\n        <div style=\"margin-bottom: 0.5em;\"><img src=\"/img/button_mini_general_02.gif\" /> <a href=\"all\">To Syllabus</a></div>\r\n      </td>\r\n    </tr>\r\n    <tr><td bgcolor=\"#9DA0B4\" class=\"th_top_normal\" align=\"center\" colspan=\"4\"></td></tr>\r\n\r\n    <tr>\r\n      <td align=\"center\" class=\"th_normal\"><span class=\"\">Faculty/<br />Graduate School</span></td>\r\n      <td class=\"odd_normal\">\r\n        <select name=\"condition.departmentNo\" id=\"select_departmentNo\">\r\n          <option value=\"\" class=\"form_disable\">----</option>\r\n          <option value=\"80\" selected>Liberal Arts and General Education Courses</option>\r\n              <option value=\"1\" >Faculty of Letters</option>\r\n              <option value=\"4\" >Faculty of Education</option>\r\n              <option value=\"6\" >Faculty of Law</option>\r\n              <option value=\"8\" >Faculty of Economics</option>\r\n              <option value=\"10\" >Faculty of Science</option>\r\n              <option value=\"12\" >Faculty of Medicine (Medicine)</option>\r\n              <option value=\"117\" >Faculty of Medicine (Human Health Science)</option>\r\n              <option value=\"14\" >Faculty of Pharmaceutical Sciences</option>\r\n              <option value=\"16\" >Faculty of Engineering</option>\r\n              <option value=\"18\" >Faculty of Agriculture</option>\r\n              <option value=\"61\" >Faculty of Integrated Human Studies</option>\r\n              <option value=\"2\" >Graduate School of Letters</option>\r\n              <option value=\"3\" >Graduate School of Education</option>\r\n              <option value=\"5\" >Graduate School of Law (Legal and Political Studies)</option>\r\n              <option value=\"114\" >Law School</option>\r\n              <option value=\"7\" >Graduate School of Economics</option>\r\n              <option value=\"9\" >Graduate School of Science</option>\r\n              <option value=\"11\" >Graduate School of Medicine (Medicine/Medical Sience/Public Health)</option>\r\n              <option value=\"116\" >Graduate School of Medicine (Human Health Science)</option>\r\n              <option value=\"15\" >Graduate School of Pharmaceutical Sciences</option>\r\n              <option value=\"17\" >Graduate School of Engineering</option>\r\n              <option value=\"19\" >Graduate School of Agriculture</option>\r\n              <option value=\"59\" >Graduate School of Human and Environmental Studies</option>\r\n              <option value=\"62\" >Graduate School of Energy Science</option>\r\n              <option value=\"64\" >Graduate School of Asian and African Area Studies</option>\r\n              <option value=\"66\" >Graduate School of Informatics</option>\r\n              <option value=\"69\" >Graduate School of Biostudies</option>\r\n              <option value=\"71\" >Graduate School of Global Environmental Studies</option>\r\n              <option value=\"73\" >School of Government</option>\r\n              <option value=\"74\" >Graduate School of Management</option>\r\n              <option value=\"119\" >Graduate School of Advanced Integrated Studies in Human Survivability</option>\r\n              </select>\r\n      </td>\r\n      <td align=\"center\" class=\"th_normal\" rowspan=\"9\" nowrap><span class=\"\">Day / period</span></td>\r\n      <td class=\"odd_normal\" rowspan=\"9\" align=\"center\">\r\n\r\n        <table border=\"0\" width=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n\r\n          <tr>\r\n            <td align=\"center\" colspan=\"7\">\r\n\r\n              <table border=\"0\" class=\"timetable_table\" width=\"0\" cellspacing=\"\" cellpadding=\"2\" style=\"margin-top:5px\" id=\"week_schedule_holder\">\r\n                <tr class=\"th_normal \" align=\"center\">\r\n                  <td class=\"timetable_sell\"><img src=\"/img/0.gif\" width=\"1\" height=\"1\" alt=\"\" id=\"id_img_1370_1\" ></td>\r\n                  <td class=\"timetable_sell\">1</td>\r\n                  <td class=\"timetable_sell\">2</td>\r\n                  <td class=\"timetable_sell\">3</td>\r\n                  <td class=\"timetable_sell\">4</td>\r\n                  <td class=\"timetable_sell\">5</td>\r\