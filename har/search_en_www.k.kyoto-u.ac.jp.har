            "text": ".list_0 {\n\theight:5px;\n\tclear:both;\n}\n.print_b{\n\tdisplay:none;\n}\n.print_i{\n\tdisplay:none;\n}\n/* ---+++++++++ font-size +++++++++++--- */\n.f1 {\n\tfont-size: 1px\n}\n.f9 {\n\tfont-size: 9px\n}\n.f10 {\n\tfont-size: 10px\n}\n.f11 {\n\tfont-size: 11px\n}\n.f12 {\n\tfont-size: 12px\n}\n.f14 {\n\tfont-size: 15px\n}\n.f18 {\n\tfont-size: 18px\n}\n.x70 {\n\tfont-size: 70%\n}\n.x80 {\n\tfont-size: 80%\n}\n.x90 {\n\tfont-size: 95%\n}\n.x100 {\n\tfont-size: 100%\n}\n.x120 {\n\tfont-size: 120%\n}\n.x140 {\n\tfont-size: 140%\n}\n.x160 {\n\tfont-size: 160%\n}\n\n\n/* ---+++++++++ line-height +++++++++++--- */\n.h50 {\n\tline-height: 50%\n}\n.h100 {\n\tline-height: 100%\n}\n.h110 {\n\tline-height: 110%\n}\n.h120 {\n\tline-height: 120%\n}\n.h130 {\n\tline-height: 130%\n}\n.h140 {\n\tline-height: 140%\n}\n.h150 {\n\tline-height: 150%\n}\n.h160 {\n\tline-height: 160%\n}\n\n\n/* ---+++++++++ margin +++++++++++--- */\n.ml5 {\n\tmargin-left: 5px\n}\n.ml10 {\n\tmargin-left: 10px\n}\n.ml15 {\n\tmargin-left: 15px\n}\n.ml25 {\n\tmargin-left: 25px\n}\n.mr5 {\n\tmargin-right: 5px\n}\n.mr10 {\n\tmargin-right: 10px\n}\n.mr15 {\n\tmargin-right: 15px\n}\n.mr20 {\n\tmargin-right: 20px\n}\n.ml35 {\n\tmargin-left: 35px\n}\n.mr35 {\n\tmargin-right: 35px\n}\n.ml55 {\n\tmargin-left: 55px\n}\n.mr55 {\n\tmargin-right: 55px\n}\n.ml75 {\n\tmargin-left: 75px\n}\n.mr75 {\n\tmargin-right: 75px\n}\n\n\n/* ---+++++++++ text-align +++++++++++--- */\n.tr{\n\ttext-align:right;\n}\n.tl{\n\ttext-align:left;\n}\n.tc{\n\ttext-align:center;\n}\n.vt{\n\tvertical-align:top;\n}\n.vb{\n\tvertical-align:bottom;\n}\n.vm{\n\tvertical-align:middle;\n}\n\n\n/* ---+++++++++ float +++++++++++--- */\n.fl{\n\tfloat:left;\n}\n.fr{\n\tfloat:right;\n}\n.fn{\n\tclear:both;\n}\n\n\n/* ---+++++++++ font-weight +++++++++++--- */\n\n.no_bold{\n\tfont-weight:400;\n}\n.bold{\n\tfont-weight:bold;\n}\n\n\n/* ---+++++++++ font-color +++++++++++--- */\n.fc_o{\n\tcolor:#eb6100;\n}\n.fc_b{\n\tcolor:#0068B7;\n}\n.fc_g{\n\tcolor:#45780a;\n}\n.fc_gray{\n\tcolor:#959595;\n}\n.fc_r{\n\tcolor:#ff0000;\n}\n\n\n/* ---+++++++++ tab +++++++++++--- */\n.textarea_box_780x80{\n\tfont-size:100%;\n\twidth:780px;\n\theight:80px;\n}\n.textarea_box_380x80{\n\tfont-size:100%;\n\twidth:380px;\n\theight:80px;\n}\n.textarea_box_x90x50{\n\tfont-size:100%;\n\twidth:90%;\n\theight:50px;\n}\n.text_box_550{\n\tfont-size:100%;\n\twidth:550px;\n}\n.text_box_375{\n\tfont-size:100%;\n\twidth:375px;\n}\n.text_box_300{\n\tfont-size:100%;\n\twidth:300px;\n}\n.text_box_275{\n\tfont-size:100%;\n\twidth:275px;\n}\n.text_box_250{\n\tfont-size:100%;\n\twidth:250px;\n}\n.text_box_x70{\n\tfont-size:100%;\n\twidth:70%;\n}\n.text_box_120{\n\tfont-size:100%;\n\twidth:120px;\n}\n.text_box_70{\n\tfont-size:100%;\n\twidth:70px;\n}\n.text_box_40{\n\tfont-size:100%;\n\twidth:40px;\n}\n.check_box_a{\n\tmargin:5px 5px 0px 5px;\n}\n\ntable.buttonList {border-collapse:collapse;}\ntable.buttonList td { padding: 0px;}\n\n.buttonList td{\n\tfont-size:1px;\n}\n.buttonList td form{\n\theight:22px;\n}\n.buttonList td a img{\n\t_height:22px;\n\tpadding:0px;\n}\n\ntable.button_list {border-collapse:collapse;}\ntable.button_list td { padding: 0px; margin: 0px; }\n\n.button_list td{\n\tfont-size:1px;\n}\n.button_list td form{\n\theight:22px;\n}\n.button_list td a img{\n\t_height:22px;\n\tpadding:0px;\n}\n.login_text_box {\n  font-size: 12px\n  font-family: monospace;\n}\n\ntextarea {\n  font-size: 100%;\n  font-family: inherit;\n}\n\n.pager_link {\n  color: blue;\n}\n\n.ime_off {\n\time-mode: disabled;\n}\n\n\n\n"
