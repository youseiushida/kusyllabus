            "mimeType": "text/css",
            "text": "/* ---- common style ---- */\r\n\r\n* {margin: 0; padding: 0;}\r\n\r\nbody {\r\n}\r\n\r\nimg {\r\n  border-style: none;\r\n  vertical-align:top;\r\n}\r\n\r\nul {\r\n  list-style-type: none;\r\n}\r\n\r\ntable {\r\n  text-align: left;\r\n}\r\n\r\ntd {\r\n  padding-left: 0.2em;\r\n  padding-right: 0.2em;\r\n}\r\n\r\n\r\noption {\r\n  padding-left: 0.2em;\r\n  padding-right: 0.2em;\r\n}\r\n\r\n\r\n.red_border {\r\n  border: red 1px solid;\r\n  padding: 10px;\r\n}\r\n\r\n.red_border2 {\r\n  border: red 2px solid;\r\n}\r\n\r\n.red_border2 td {\r\n  border-top: red 2px solid;\r\n  border-bottom: red 2px solid;\r\n}\r\n\r\n.red_border2 td.left {\r\n  border-left: red 2px solid;\r\n}\r\n\r\n.red_border2 td.right_cell {\r\n  border-right: red 2px solid;\r\n}\r\n\r\n.width_100 {\r\n  width: 100px;\r\n}\r\n\r\n.width_700 {\r\n  width: 700px;\r\n}\r\n\r\n\r\n\r\n/* ---- layout ---- */\r\n.explanation {\r\n\tline-height:130%;\r\n\tmargin-left: 40px;\r\n        margin-right: 40px;\r\n        margin-top: 10px;\r\n        margin-bottom: 10px;\r\n}\r\n\r\n\r\n.lesson_plan{\r\n\tbackground:#000000;\r\n}\r\n.lesson_plan_subheading {\r\n        font-size: 12px; color: #555555;\r\n}\r\n.lesson_plan_sell {\r\n        border-top-style: solid; border-right-style: solid; border-left-style: solid; border-bottom-style: solid\r\n}\r\n.cell_sunday {\r\n        background-color: #f1dfdb\r\n}\r\n.cell_saturday {\r\n        background-color: #dbf1df\r\n}\r\n\r\n.lesson_plan tr{\r\n\tvertical-align:top;\r\n}\r\n.lesson_plan td.td_normal{\r\n\tpadding:5px 0px 5px 0px;\r\n\tbackground:#ffffff;\r\n}\r\n.lesson_plan td.odd_normal{\r\n\tvertical-align:top;\r\n}\r\n.lesson_plan .th_top_normal {\r\n  background-color: #9da0b4;\r\n  height: 8px;\r\n}\r\n\r\n\r\n.th_top_special {\r\n  background-color: #3fb456;\r\n  height: 8px;\r\n}\r\n.th_top_normal {\r\n  background-color: #9da0b4;\r\n  height: 8px;\r\n}\r\n.th_normal {\r\n  background-color: #cccdd8;\r\n  font-weight: bold;\r\n}\r\n.th_normal_small {\r\n  background-color: #cccdd8;\r\n  font-weight: bold;\r\n}\r\n.th_normal_small td {\r\n  padding: 0;\r\n  font-size: 8px;\r\n}\r\n\r\n.td_normal {\r\n  background-color: #ffffff;\r\n}\r\n.odd_normal {\r\n\tbackground-color: #fff3c1;\r\n}\r\n.odd_normal td,.even_normal td{\r\n\tpadding:3px 0px 3px 3px;\r\n}\r\n\r\n.odd_normal_small {\r\n  background-color: #fff3c1;\r\n}\r\n.even_normal_small {\r\n  background-color: #e5edf3;\r\n}\r\n.odd_normal_small td,.even_normal td{\r\n  padding:0 0 0 3px;\r\n}\r\n\r\n.warn_normal {\r\n\tbackground-color: #ffc2c1;\r\n}\r\n.orange_normal {\r\n\tbackground-color: #ffd980;\r\n}\r\n.gray_normal {\r\n\tbackground-color: #EEEEEE;\r\n}\r\n.even_normal {\r\n\tbackground-color: #e5edf3;\r\n}\r\n.odd_dark {\r\n  background-color: #ffcc80;\r\n}\r\n.even_dark {\r\n  background-color: #bbccee;\r\n}\r\n.notice_background {\r\n    background-color: #ffc2c1;\r\n}\r\n.date_weekday {\r\n  font-weight: bold; color: #333333\r\n}\r\n.date_saturday {\r\n  font-weight: bold; color: #0000ff\r\n}\r\n.date_sunday {\r\n  font-weight: bold; color: #ff3300\r\n}\r\n.cell_sunday {\r\n  background-color: #f1dfdb\r\n}\r\n.cell_saturday {\r\n  background-color: #dbf1df\r\n}\r\n.even_special {\r\n  background-color: #dbf1df\r\n}\r\n.date_selected {\r\n  border-right: #ff0000 2px; border-top: #ff0000 2px; border-left: #ff0000 2px; border-bottom: #ff0000 2px\r\n}\r\n.odd_special {\r\n  background-color: #fff3c1\r\n}\r\n.content {\r\n  margin-left: 40px;\r\n  margin-top: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n.content2 {\r\n  margin-left: 100px;\r\n  margin-top: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\ntable.wordwrap {\r\n  table-layout: fixed;\r\n}\r\n\r\ntable.wordwrap td {\r\n  word-wrap: break-word;\r\n  overflow-wrap: break-word;\r\n}\r\n\r\n.relaxed_table {\r\n  text-align: left;\r\n}\r\n\r\n  .relaxed_table td{\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n  .relaxed_table td div.annotation{\r\n    padding-left: 2em