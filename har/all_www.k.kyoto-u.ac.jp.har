us?lectureNo=4426&departmentNo=11\">医療データ科学　【領域2】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4221&departmentNo=11\">感染症疫学　【領域３】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4301&departmentNo=11\">産業・環境衛生学　【領域３】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4303&departmentNo=11\">保健・医療の経済評価　【領域４】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4406&departmentNo=11\">医療制度・政策・経済 【領域４】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4276&departmentNo=11\">医薬政策・行政　【領域４】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4304&departmentNo=11\">社会健康医学と健康政策　【領域４】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4203&departmentNo=11\">医学コミュニケーション・基礎　【領域５】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4389&departmentNo=11\">社会疫学【領域５】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4217&departmentNo=11\">基礎医療倫理学　【領域５】</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4213&departmentNo=11\">行動科学　【領域５】</a>\r\n                        </div>\r\n                <div class=\"s