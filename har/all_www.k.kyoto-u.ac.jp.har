ureNo=4384&departmentNo=11\">医学基礎　I   「解剖学」</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4407&departmentNo=11\">QOL・PRO評価法</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4158&departmentNo=11\">アントレプレナーシップ</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4185&departmentNo=11\">アントレプレナーシップ特論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4422&departmentNo=11\">グローバルヘルス通論 </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4162&departmentNo=11\">ゲノム科学と医療</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4280&departmentNo=11\">ヘルスサイエンス研究の進め方 </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4428&departmentNo=11\">データ解析の方法 </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4245&departmentNo=11\">人間生態学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4429&departmentNo=11\">保健活動論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4339&departmentNo=11\">健康デザイン論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4417&departmentNo=11\">健康・予防医療学領域の実装科学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4306&departmentNo=11\">健康情報学　I  </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4387&departmentNo=11\">健康情報学　II </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4431&departmentNo=11\">公共政策と健康危機管理</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4420&departmentNo=11\">創薬医学特論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4419&departmentNo=11\">医療ビジネス・イノベーション概論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4442&departmentNo=11\">医療倫理学各論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4176&departmentNo=11\">医療社会学・基礎</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4214&departmentNo=11\">医薬品の開発と評価</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4241&departmentNo=11\">医薬品・医療機器の開発計画、薬事と審査</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4243&departmentNo=11\">基礎人類遺伝学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4159&departmentNo=11\">契約実務演習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4248&departmentNo=11\">文献検索法</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4224&departmentNo=11\">文献評価法</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4433&departmentNo=11\">災害時の保健医療福祉における情報管理･活用</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4432&departmentNo=11\">災害時の避難生活支援 </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4430&departmentNo=11\">健康危機管理セミナー</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4180&departmentNo=11\">特許法特論・演習（前期）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4163&departmentNo=11\">特許法特論・演習（後期）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4382&departmentNo=11\">環境・感染症論  </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4391&departmentNo=11\">環境曝露・リスク評価 </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4332&departmentNo=11\">生存時間解析</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4434&departmentNo=11\">産業保健と労働関連法</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4155&departmentNo=11\">知的財産法演習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4211&departmentNo=11\">知的財産経営学　基礎</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4255&departmentNo=11\">社会健康医学課外実習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4333&departmentNo=11\">統計モデルとその応用</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4331&departmentNo=11\">統計的推測の基礎</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4315&departmentNo=11\">臨床試験の統計的方法</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4448&departmentNo=11\">機械学習概論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4447&departmentNo=11\">医療データ科学実習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4446&departmentNo=11\">データ解析実習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4435&departmentNo=11\">臨床遺伝学・遺伝カウンセリング</a>\r\n                        </div>\r\n             