 +\r\n          '  </div>' +\r\n          '</center>'\r\n        );\r\n      \r\n      jQuery(\".loading_modal_background\").height(height).width(width).addClass(\"now-loading\").show();\r\n      jQuery(\".loading_modal_body\").addClass(\"now-loading\").show();\r\n      adjustModalPosition();\r\n    };\r\n\r\n    var absolutePath = function(path) {\r\n      var e = document.createElement('span');\r\n      e.innerHTML = '<a href=\"' + path + '\" />';\r\n      return e.firstChild.href;\r\n    }\r\n\r\n    var regTimeslotPage = /\\/student\\/la\\/timeslot\\//;\r\n    jQuery(\"a\").bind(\"click\", function(e) {\r\n      if (!e.customClickTarget) e.customClickTarget = e.currentTarget;\r\n    });\r\n\r\n    jQuery(\"body\").bind(\"click\", function(e) {\r\n      if (e.customClickTarget && !e.defaultPrevented) {\r\n        var $a = jQuery(e.customClickTarget);\r\n        var path = absolutePath($a.attr(\"href\"));\r\n        if (!$a.attr(\"target\") && path.match(regTimeslotPage) && !$a.is(\".no-loading-modal\")) {\r\n          openConfirmWindow();\r\n        }\r\n      }\r\n    });\r\n    jQuery(\"body\").bind(\"submit\", function(e) {\r\n      if (!e.defaultPrevented) {\r\n        var $f = jQuery(e.target);\r\n        var path = absolutePath($f.attr(\"action\"));\r\n        if (path.match(regTimeslotPage) && !$f.is(\".no-loading-modal\")) {\r\n          openConfirmWindow();\r\n        }\r\n      }\r\n    });\r\n  });\r\n</script>\r\n</body>\r\n</html>\r\n"
