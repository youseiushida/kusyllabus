blank\">C17　整形外科学・リハビリテーション医学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"https://www.med.kyoto-u.ac.jp/for_students/affairs_m/class/\" target=\"_blank\">C18　麻酔科学・集中治療医学・救急医学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"https://www.med.kyoto-u.ac.jp/for_students/affairs_m/class/\" target=\"_blank\">C19　画像診断・臨床腫瘍学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"https://www.med.kyoto-u.ac.jp/for_students/affairs_m/class/\" target=\"_blank\">C20　医療情報学</a>\r\n                        </div>\r\n                </div>\r\n            </div>\r\n          </div>\r\n      </div>\r\n    <div>\r\n        <div class=\"departmentName\">\r\n          医学部(人間)<span class=\"departmentIcon\">＋</span>\r\n        </div>\r\n        <div class=\"departmentSection\" style=\"display: none\">\r\n          <div>\r\n              <div class=\"openTitle\">\r\n                専門基礎科目<span class=\"openTitleIcon\">＋</span>\r\n              </div>\r\n              <div class=\"syllabusses\">\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4715&departmentNo=117\">人間健康科学I（看護学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4716&departmentNo=117\">人間健康科学I（理学療法学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4727&departmentNo=117\">人間健康科学I（作業療法学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4758&departmentNo=117\">人間健康科学I（総合医療科学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4554&departmentNo=117\">人間健康科学II</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4717&departmentNo=117\">人間健康科学III（看護学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4718&departmentNo=117\">人間健康科学III（理学療法学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4728&departmentNo=117\">人間健康科学III （作業療法学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4757&departmentNo=117\">人間健康科学III（総合医療科学）</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4556&departmentNo=117\">人間健康科学IV</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4557&departmentNo=117\">人間健康科学V</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4558&departmentNo=117\">解剖学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4559&departmentNo=117\">肉眼解剖学I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4619&departmentNo=117\">肉眼解剖学II</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4560&departmentNo=117\">運動機能解剖学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4561&departmentNo=117\">生理学I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4562&departmentNo=117\">生理学II</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4564&departmentNo=117\">神経生理学I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4566&departmentNo=117\">基礎運動学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4567&departmentNo=117\">臨床コミュニケーション論I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4568&departmentNo=117\">病理学概論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4569&departmentNo=117\">薬剤・薬理学概論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4570&departmentNo=117\">生体防御学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4571&departmentNo=117\">生化学概論</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4572&departmentNo=117\">公衆衛生学I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4573&departmentNo=117\">臨床疾病論A</a>\r\n                        </div>\r\n                <di