117\">医療情報システム学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4690&departmentNo=117\">法医学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4705&departmentNo=117\">iPS再生医療学各論  </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4691&departmentNo=117\">臨床実習</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4692&departmentNo=117\">総合医療特別セミナーI</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4706&departmentNo=117\">総合医療特別セミナーII  </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4707&departmentNo=117\">卒業研究  </a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4738&departmentNo=117\">放射線医学物理学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4739&departmentNo=117\">非侵襲画像検査学</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4752&departmentNo=117\">血液学I</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4753&departmentNo=117\">血液学II</a>\r\n                        </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"department_syllabus?lectureNo=4756&depa