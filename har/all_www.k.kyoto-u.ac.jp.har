          "content": {
            "size": 2202684,
            "mimeType": "text/html",
            "compression": -1493,
            "text": "<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n  <head>\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=windows-31j\" />\r\n    <meta http-equiv=\"Content-Script-Type\" content=\"text/javascript\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/behavior.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/layout.css\">\r\n    <link rel=\"stylesheet\" type=\"text/css\" href=\"/css/la_style.css\">\r\n    <script type=\"text/javascript\" src=\"/js/prototype.js\"> </script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery-2.1.4.js\"> </script>\r\n    <script>\r\n     jQuery.noConflict();\r\n    </script>\r\n    <script type=\"text/javascript\" src=\"/js/jquery_auto.js\"> </script>\r\n\r\n    <title>京都大学教務情報システム</title>\r\n  <link rel=\"stylesheet\" href=\"/css/webfont.css\" />\r\n\r\n<style>\r\n  .css-submit-button {\r\n    display: inline-block;\r\n  }\r\n  input::-webkit-contacts-auto-fill-button {\r\n    visibility: hidden;\r\n    display: none !important;\r\n    pointer-events: none;\r\n    position: absolute;\r\n    right: 0;\r\n  }\r\n</style>\r\n\r\n<script type=\"text/javascript\">\r\n  jQuery(function() {\r\n    jQuery(\".css-submit-button\").click(function(e) {\r\n      jQuery(e.target).parents(\"form\").submit();\r\n    });\r\n  });\r\n</script>\r\n</head>\r\n  <body onload=\"\">\r\n  <div id=\"frame\">\r\n    <div id=\"header\">\n  <div class=\"header_left\">\n    <img src=\"/img/zk_logo_l.gif\" alt=\"TOPへ\"  id=\"id_img_10_0\" >\n  </div>\n\n  <div class=\"header_right\">\n    <div class=\"logo\"><img src=\"/img/zk_logo_r.gif\" alt=\"\" id=\"id_img_10_1\" ></div>\n\n    <div class=\"header_menu\">\n      <ul class=\"header_menu_left\">      \n      </ul>\n\n      <ul class=\"header_menu_right three_storied\">\n        <li style=\"height: 24px\">&nbsp;</li>\n        <li style=\"height: 24px\"><a href=\"/external/open_syllabus/top\" id=\"id_a_10_6\" ><img src=\"/img/zk_header_home_o.gif\" alt=\"KULASIS TOP\" /></a></li>\n      </ul>\n    </div>\n\n  </div>\n</div>\n<div id=\"wrapper\">\r\n      <div class=\"contents\" style=\"width: 968px\">\r\n        <div class=\"right\" style=\"margin-top: 3px;\">\r\n          <span class=\"link\"><a href=\"/external/open_syllabus/all?display_lang=en\">English</a></span> |\r\n          <span class=\"link\"><a href=\"/external/open_syllabus/all?display_lang=jp\">日本語</a></span>\r\n        </div>\r\n\r\n        <!-- contents -->\r\n\r\n        <style>\r\n    .content {\r\n        margin-right: 40px;\r\n    }\r\n    .syllabusses {\r\n        margin-left: 2em;\r\n        margin-bottom: 2em;\r\n    }\r\n    .departmentName {\r\n        font-size: 150%;\r\n        padding: 5px;\r\n        padding-left: 1em;\r\n        margin: 5px;\r\n        background-color: #9ac2e9;\r\n        margin-top: 0.5em;\r\n        cursor: pointer;\r\n    }\r\n    .departmentIcon {\r\n        float: right;\r\n        padding-left: 5px;\r\n        padding-right: 5px;\r\n        background-color: #eeeeee;\r\n        display: inline-block;\r\n    }\r\n    .openTitle {\r\n        font-size: 120%;\r\n        padding: 5px;\r\n        padding-left: 1em;\r\n        margin: 5px;\r\n        border-bottom: medium solid #6390be;\r\n        cursor: pointer;\r\n    }\r\n    .openTitleIcon {\r\n        float: right;\r\n        padding-left: 3px;\r\n        padding-right: 3px;\r\n        background-color: #eeeeee;\r\n        display: inline-block;\r\n    }\r\n    .syllabusTitle {\r\n        margin-bottom: 4px;\r\n    }\r\n  </style>\r\n\r\n  <script>\r\n    jQuery(function() {\r\n      jQuery(\".departmentSection\").hide();\r\n      jQuery(\".syllabusses\").hide();\r\n      jQuery(\".departmentName\").bind('click', function() {\r\n          var $parent = jQuery(this).parent();\r\n          var $icon = $parent.find(\".departmentIcon\");\r\n          if ($icon.hasClass(\"opened\")) {\r\n              $icon.text(\"＋\").removeClass(\"opened\");\r\n              $parent.find(\".openTitleIcon\").removeClass(\"opened\").text(\"＋\");\r\n              $parent.find(\".syllabusses\").hide();\r\n              $parent.find(\".departmentSection\").animate({ height: 'hide'}, \"fast\");\r\n          } else {\r\n              $icon.text(\"―\").addClass(\"opened\");\r\n              $parent.find(\".departmentSection\").animate({ height: 'show'}, \"fast\");\r\n          }\r\n      });\r\n      jQuery(\".openTitle\").bind('click', function() {\r\n          var $parent = jQuery(this).parent();\r\n          var $icon = $parent.find(\".openTitleIcon\");\r\n          if ($icon.hasClass(\"opened\")) {\r\n              $icon.text(\"＋\").removeClass(\"opened\");\r\n          } else {\r\n              $icon.text(\"―\").addClass(\"opened\");\r\n          }\r\n          $parent.find(\".syllabusses\").toggle(400);\r\n      });\r\n    });\r\n  </script>\r\n\r\n  <div class=\"title\">\r\n    <div style=\"font-family: 'KulasisWebFont'; font-weight: bold; color: #020C4A; font-size: 24px;\">\r\n      <img src=\"/img/mark_01.gif\" alt=\"\" id=\"id_img_1239_0\">\r\n      シラバス一覧\r\n    </div>\r\n  </div>\r\n\r\n  <!-- +++++++++++++++++++++ contents +++++++++++++++++++++ -->\r\n\r\n  <br />\r\n\r\n  <div class=\"content\">\r\n    <div>\r\n        <div class=\"departmentName\">\r\n          全学共通科目<span class=\"departmentIcon\">＋</span>\r\n        </div>\r\n        <div class=\"departmentSection\" style=\"display: none\">\r\n          <div>\r\n              <div class=\"openTitle\">\r\n                人文・社会科学科目群／哲学・思想<span class=\"openTitleIcon\">＋</span>\r\n              </div>\r\n              <div class=\"syllabusses\">\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61323\">哲学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61325\">哲学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61324\">哲学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=63689\">哲学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61326\">哲学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61328\">哲学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61327\">哲学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61333\">倫理学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61332\">倫理学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61335\">倫理学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61334\">倫理学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61336\">論理学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61337\">論理学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61339\">論理学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61338\">論理学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61321\">西洋社会思想史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61322\">西洋社会思想史II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61307\">科学論Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61308\">科学論II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61329\">東洋社会思想史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64248\">東洋社会思想史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61342\">東洋社会思想史II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64249\">東洋社会思想史II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61312\">宗教学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61311\">宗教学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61313\">人間実践論Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61314\">人間実践論II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61309\">自己存在論Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61310\">自己存在論II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61330\">認識人間学Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61331\">認識人間学II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61343\">哲学・文化史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61344\">哲学・文化史II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61341\">哲学基礎ゼミナール</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61318\">倫理学基礎ゼミナール</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61316\">西洋思想史基礎ゼミナール</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61320\">科学論基礎ゼミナール</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61585\">The History of Eastern Thought I-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61586\">Science of Religion I-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=62362\">History of Modern Science-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=62453\">Philosophy of Modern Science-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=62431\">Logic II-E2 :Inductive &amp; Scientific Reasoning</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=63570\">Theories of Religion in the Social Sciences-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64012\">Japanese Philosophy I-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64013\">Japanese Philosophy II-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64014\">Philosophy of Nature I-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64015\">Philosophy of Nature II-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64196\">Ethics I-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64197\">Ethics II-E2</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64399\">宗教学各論I（死生学）</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64400\">宗教学各論II（死生学）</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64710\">統合型複合科目（人社群p） ：実践的・人文社会科学入門　HP01</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64711\">統合型複合科目（人社群p） ：実践的・人文社会科学入門　HP02</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=64712\">統合型複合科目（人社群p） ：実践的・人文社会科学入門　HP03</a>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n          <div>\r\n              <div class=\"openTitle\">\r\n                人文・社会科学科目群／歴史・文明<span class=\"openTitleIcon\">＋</span>\r\n              </div>\r\n              <div class=\"syllabusses\">\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61508\">現代文明Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61507\">現代文明Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61516\">現代文明II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61509\">現代文明II</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61362\">アメリカ現代史入門</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61370\">西洋史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61369\">西洋史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61366\">西洋史Ｉ</a>\r\n                    </div>\r\n                <div class=\"syllabusTitle\">\r\n                    <a href=\"la_syllabus?lectureNo=61365\">西洋