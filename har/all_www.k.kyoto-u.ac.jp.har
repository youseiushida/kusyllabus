          "content": {
            "size": 17151,
            "mimeType": "text/css",
            "text": "/* ---- common style ---- */\r\n\r\n* {margin: 0; padding: 0;}\r\n\r\nbody {\r\n}\r\n\r\nimg {\r\n  border-style: none;\r\n  vertical-align:top;\r\n}\r\n\r\nul {\r\n  list-style-type: none;\r\n}\r\n\r\ntable {\r\n  text-align: left;\r\n}\r\n\r\ntd {\r\n  padding-left: 0.2em;\r\n  padding-right: 0.2em;\r\n}\r\n\r\n\r\noption {\r\n  padding-left: 0.2em;\r\n  padding-right: 0.2em;\r\n}\r\n\r\n\r\n.red_border {\r\n  border: red 1px solid;\r\n  padding: 10px;\r\n}\r\n\r\n.red_border2 {\r\n  border: red 2px solid;\r\n}\r\n\r\n.red_border2 td {\r\n  border-top: red 2px solid;\r\n  border-bottom: red 2px solid;\r\n}\r\n\r\n.red_border2 td.left {\r\n  border-left: red 2px solid;\r\n}\r\n\r\n.red_border2 td.right_cell {\r\n  border-right: red 2px solid;\r\n}\r\n\r\n.width_100 {\r\n  width: 100px;\r\n}\r\n\r\n.width_700 {\r\n  width: 700px;\r\n}\r\n\r\n\r\n\r\n/* ---- layout ---- */\r\n.explanation {\r\n\tline-height:130%;\r\n\tmargin-left: 40px;\r\n        margin-right: 40px;\r\n        margin-top: 10px;\r\n        margin-bottom: 10px;\r\n}\r\n\r\n\r\n.lesson_plan{\r\n\tbackground:#000000;\r\n}\r\n.lesson_plan_subheading {\r\n        font-size: 12px; color: #555555;\r\n}\r\n.lesson_plan_sell {\r\n        border-top-style: solid; border-right-style: solid; border-left-style: solid; border-bottom-style: solid\r\n}\r\n.cell_sunday {\r\n        background-color: #f1dfdb\r\n}\r\n.cell_saturday {\r\n        background-color: #dbf1df\r\n}\r\n\r\n.lesson_plan tr{\r\n\tvertical-align:top;\r\n}\r\n.lesson_plan td.td_normal{\r\n\tpadding:5px 0px 5px 0px;\r\n\tbackground:#ffffff;\r\n}\r\n.lesson_plan td.odd_normal{\r\n\tvertical-align:top;\r\n}\r\n.lesson_plan .th_top_normal {\r\n  background-color: #9da0b4;\r\n  height: 8px;\r\n}\r\n\r\n\r\n.th_top_special {\r\n  background-color: #3fb456;\r\n  height: 8px;\r\n}\r\n.th_top_normal {\r\n  background-color: #9da0b4;\r\n  height: 8px;\r\n}\r\n.th_normal {\r\n  background-color: #cccdd8;\r\n  font-weight: bold;\r\n}\r\n.th_normal_small {\r\n  background-color: #cccdd8;\r\n  font-weight: bold;\r\n}\r\n.th_normal_small td {\r\n  padding: 0;\r\n  font-size: 8px;\r\n}\r\n\r\n.td_normal {\r\n  background-color: #ffffff;\r\n}\r\n.odd_normal {\r\n\tbackground-color: #fff3c1;\r\n}\r\n.odd_normal td,.even_normal td{\r\n\tpadding:3px 0px 3px 3px;\r\n}\r\n\r\n.odd_normal_small {\r\n  background-color: #fff3c1;\r\n}\r\n.even_normal_small {\r\n  background-color: #e5edf3;\r\n}\r\n.odd_normal_small td,.even_normal td{\r\n  padding:0 0 0 3px;\r\n}\r\n\r\n.warn_normal {\r\n\tbackground-color: #ffc2c1;\r\n}\r\n.orange_normal {\r\n\tbackground-color: #ffd980;\r\n}\r\n.gray_normal {\r\n\tbackground-color: #EEEEEE;\r\n}\r\n.even_normal {\r\n\tbackground-color: #e5edf3;\r\n}\r\n.odd_dark {\r\n  background-color: #ffcc80;\r\n}\r\n.even_dark {\r\n  background-color: #bbccee;\r\n}\r\n.notice_background {\r\n    background-color: #ffc2c1;\r\n}\r\n.date_weekday {\r\n  font-weight: bold; color: #333333\r\n}\r\n.date_saturday {\r\n  font-weight: bold; color: #0000ff\r\n}\r\n.date_sunday {\r\n  font-weight: bold; color: #ff3300\r\n}\r\n.cell_sunday {\r\n  background-color: #f1dfdb\r\n}\r\n.cell_saturday {\r\n  background-color: #dbf1df\r\n}\r\n.even_special {\r\n  background-color: #dbf1df\r\n}\r\n.date_selected {\r\n  border-right: #ff0000 2px; border-top: #ff0000 2px; border-left: #ff0000 2px; border-bottom: #ff0000 2px\r\n}\r\n.odd_special {\r\n  background-color: #fff3c1\r\n}\r\n.content {\r\n  margin-left: 40px;\r\n  margin-top: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n.content2 {\r\n  margin-left: 100px;\r\n  margin-top: 10px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\ntable.wordwrap {\r\n  table-layout: fixed;\r\n}\r\n\r\ntable.wordwrap td {\r\n  word-wrap: break-word;\r\n  overflow-wrap: break-word;\r\n}\r\n\r\n.relaxed_table {\r\n  text-align: left;\r\n}\r\n\r\n  .relaxed_table td{\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n  .relaxed_table td div.annotation{\r\n    padding-left: 2em;\r\n  }\r\n\r\n  .relaxed_table td.th_top_normal {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\nul.relaxed_list li {\r\n  padding-bottom: 1em;\r\n}\r\nul.relaxed_list li .annotation{\r\n  padding-left: 2em;\r\n}\r\n\r\n\r\n.standard_list {\r\n  width: 716px;\r\n  text-align: left;\r\n}\r\n\r\n  .standard_list td {\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n\r\n  .standard_list td.th_top_normal {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\n  .standard_list td.th_top_special {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\n.scroll_list_header {\r\n  width: 680px;\r\n  text-align: left;\r\n}\r\n\r\n  .scroll_list_header td {\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n\r\n  .scroll_list_header td.th_top_normal {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\n.scroll_list {\r\n  width: 700px;\r\n  height: 200px;\r\n  overflow: auto;\r\n  overflow-y: scroll;\r\n  text-align: left;\r\n}\r\n\r\n  .scroll_list table {\r\n    width: 680px;\r\n  }\r\n\r\n  .scroll_list td {\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n\r\n  .scroll_list td.th_top_normal {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\n\r\n.no_scroll_list {\r\n  width: 700px;\r\n  text-align: left;\r\n}\r\n\r\n  .no_scroll_list td {\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n\r\n  .no_scroll_list td.th_top_normal {\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n\r\n.form_table {\r\n  text-align: left;\r\n}\r\n\r\n  .form_table td{\r\n    padding-top: 0.1em;\r\n    padding-bottom: 0.1em;\r\n    padding-left: 0.5em;\r\n    padding-right: 0.5em;\r\n    font-weight: normal;\r\n  }\r\n\r\n  .form_table td.th_top_normal {\r\n    padding-left: 0.2em;\r\n    padding-right: 0.2em;\r\n  }\r\n\r\n\r\ndiv#prelang_content {\r\n  padding-left: 40px;\r\n  padding-right: 40px;\r\n}\r\ndiv#prelang_office_content {\r\n  padding-top: 20px;\r\n  padding-left: 40px;\r\n  padding-right: 40px;\r\n}\r\n.prelang_selected {\r\n  color: #ff6347\r\n}\r\n.black {\r\n  color: #000000\r\n}\r\n\r\n# Depricated\r\n.prelang_list {\r\n#  text-align: center;\r\n}\r\n  .prelang_list tr.header {\r\n    background-color: #9ba0b4;\r\n    padding-top: 0px;\r\n    padding-bottom: 0px;\r\n  }\r\n  .prelang_list tr.th_normal td {\r\n    padding-left: 3px;\r\n    padding-top: 3px;\r\n    padding-bottom: 3px;\r\n  }\r\n\r\n  .prelang_list tr.item td {\r\n    background-color: #fff3c1;\r\n    padding-left: 0.5em;\r\n    padding-right: 0.5em;\r\n    padding-top: 0.5em;\r\n    padding-bottom: 0.5em;\r\n  }\r\n\r\n  .prelang_list tr.bottom_line td {\r\n      background-color: #9ba0b4;\r\n      height: 4px;\r\n  }\r\n\r\n.prelang_call_table {\r\n  table-layout: fixed;\r\n  width: 750px;\r\n}\r\n\r\n.calendar_table {\r\n  table-layout: fixed;\r\n  width: 750px;\r\n}\r\n\r\n  .calendar_table tr.period_row {\r\n    background-color: #9ba0b4;\r\n    text-align: center;\r\n  }\r\n  .calendar_table tr.weekday_row {\r\n    background-color: #fff3c1;\r\n    height: 100px;\r\n  }\r\n  .calendar_table td.weekday_label {\r\n    background-color: #9da0b4;\r\n    width: 15px;\r\n  }\r\n\r\n.data_io_form {\r\n  text-align: left;\r\n  width: 620px;\r\n  margin-bottom: 20px;\r\n}\r\n\r\n  .data_io_form td{\r\n    padding-top: 0.3em;\r\n    padding-bottom: 0.3em;\r\n    padding-left: 0.5em;\r\n    padding-right: 0.5em;\r\n    font-weight: normal;\r\n  }\r\n\r\n  .data_io_form .file_form{\r\n    border-right: 2px solid #9da0b4;\r\n  }\r\n\r\n  .data_io_form td.th_top_normal {\r\n    padding-left: 0.2em;\r\n    padding-right: 0.2em;\r\n  }\r\n\r\n  .data_io_form td.container {\r\n  }\r\n\r\n  .data_io_form td.date_top {\r\n    background-color: #9da0b4;\r\n    padding: 0px;\r\n    width: 100px;\r\n    vertical-align: top;\r\n    text-align: center;\r\n  }\r\n\r\n  .data_io_form td.date {\r\n\tbackground-color: #e5edf3;\r\n    text-align: center;\r\n  }\r\n\r\n.updated_at_form {\r\n  margin: 0px;\r\n  width: 100%;\r\n  border-collapse: collapse;\r\n}\r\n\r\n  .updated_at_form td.top {\r\n\tborder-bottom: 2px solid #9da0b4;\r\n\theight: 1.5em;\r\n  }\r\n\r\n  .updated_at_form td {\r\n    text-align: center;\r\n    padding-top: 0.3em;\r\n    padding-bottom: 0.3em;\r\n    padding-left: 0.5em;\r\n    padding-right: 0.5em;\r\n  }\r\n\r\n.timetable_table .th_normal {\r\n  padding-left: 0px;\r\n  padding-right: 0px;\r\n  font-weight: normal;\r\n}\r\n\r\n.warn {\r\n  font-weight: bold;\r\n  color: #ff0000;\r\n}\r\n\r\n.warning {\r\n  font-weight: bold;\r\n  color: #ff0000;\r\n}\r\n\r\n.notice {\r\n  color: #ff0000;\r\n}\r\n\r\n\r\n.dead_link {\r\n  text-decoration: underline;\r\n  color: #f00;\r\n\r\n}\r\n.timetable_class {\r\n        border-left: #FFa880 2px solid;\r\n        padding-left: 1px;\r\n}\r\n.timetable_special {\r\n        border-left: #80b0e8 2px solid;\r\n        padding-left: 1px;\r\n}\r\n\r\n.timetable_class_notice {\r\n  color:#FFA880;\r\n}\r\n.timetable_class_mark {\r\n  border-left:#FFA880 3px solid;\r\n}\r\n.timetable_special_notice{\r\n\tcolor:#80B0E8;\r\n}\r\n.timetable_special_mark{\r\n\tborder-left:#80B0E8 3px solid;\r\n}\r\n.timetable_reserved_notice{\r\n\tcolor:#E3FFC1;\r\n}\r\n.timetable_reserved_mark{\r\n\tborder-left:#E3FFC1 3px solid;\r\n}\r\n\r\n.title {\r\n  vertical-align: middle;\r\n  padding:0px 0px 0px 10px;\r\n}\r\n\r\n.title img {\r\n  margin-top: 5px;\r\n}\r\n\r\n.th_top_notice {\r\n  background-color: #ff9a52;\r\n  height: 8px;\r\n}\r\n\r\n.th_notice {\r\n\tbackground-color: #ffbc8c;\r\n}\r\n.odd_notice {\r\n\tbackground-color: #fff3c1;\r\n}\r\n.even_notice {\r\n\tbackground-color: #ffdbc2;\r\n}\r\n\r\n.frame_pane {\r\n  border-top: #000 1px solid;\r\n  border-bottom: #000 1px solid;\r\n  width: 100%;\r\n  height: 300px;\r\n  overflow: auto;\r\n  overflow-y: scroll;\r\n  text-align: left;\r\n}\r\n\r\n.right {\r\n  text-align: right;\r\n}\r\n\r\n.search_tab {\r\n\ttext-align:left;\r\n  width:716px;\r\n  padding:0px;\r\n  margin:0px;\r\n  border-bottom:#9da0b4 8px solid;\r\n}\r\n\r\n\r\nspan.link a {\r\n  color:#0000EE;\r\n  padding-left:5px;\r\n  padding-right:5px;\r\n  text-decoration:none;\r\n}\r\n\r\nspan.link a:hover {\r\n  color:#FF3300;\r\n  position:relative;\r\n  text-decoration:underline;\r\n}\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\nbody {\r\n  background: #FFFm;\r\n}\r\n\r\n#frame {\r\n  position: relative;\r\n  background-color: #FFF;\r\n  font-size: 80%;\r\n  color: #000;\r\n  margin: 0 auto 0 0;\r\n  width: 990px;\r\n\tbackground:#ffffff url(/img/zk_border_back.gif) repeat;\r\n}\r\n\r\n\r\n/*------------- header -------------*/\r\n#header {\r\n\twidth: 100%;\r\n\theight: 96px;\r\n}\r\n\r\n#header .header_left {\r\n\tfloat: left;\r\n\twidth: 158px;\r\n}\r\n\r\n#header .header_right {\r\n\twidth: 832px;\r\n\tfloat: left;\r\n}\r\n\r\n#header .header_right .logo {\r\n\twidth: 832px;\r\n\theight: 48px;\r\n\tbackground: #bec7e0 url(/img/zk_logo_r_back.gif) no-repeat right top;\r\n}\r\n\r\n\r\n#header .header_menu {\r\n\twidth: 832px;\r\n\tpadding: 0px 0px 0px 0px;\r\n\tmargin: 0px 0px 0px 0px;\r\n}\r\n\r\n#header .header_menu_left {\r\n\tfloat: left;\r\n\twidth: 758px;\r\n\theight: 35px;\r\n\tbackground: url(/img/zk_tab_back.gif) repeat left bottom;\r\n\tlist-style-type: none;\r\n\tmargin: 0px;\r\n\tpadding: 13px 0px 0px 0px;\r\n}\r\n\r\n#header .header_menu_left  li {\r\n\tfloat: left;\r\n}\r\n\r\n#header .header_menu_right {\r\n\tfloat: right;\r\n\twidth: 74px;\r\n\theight: 48px;\r\n\tlist-style-type: none;\r\n\tbackground: url(/img/zk_tab_back2.gif) repeat left bottom;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n#header .header_menu_right.header_menu_en_right {\r\n\tbackground: url(/img/en_tab_back.gif) repeat left bottom;\r\n}\r\n\r\n#header .header_menu_right.header_menu_gr_right {\r\n\tbackground: url(/img/gr_tab_back.gif) repeat left bottom;\r\n}\r\n\r\n#header .header_menu_right li {\r\n\tdisplay: block;\r\n  width: 74px;\r\n\tmargin: 0px;\r\n\tpadding: 0px;\r\n}\r\n\r\n#header .two_storied li {\r\n  height: 24px;\r\n}\r\n\r\n#header .three_storied li {\r\n  height: 16px;\r\n}\r\n\r\n/*------------- wrapper -------------*/\r\n#wrapper {\r\n\twidth: 100%;\r\n\tclear: both;\r\n\tborder-left:1px #000000 solid;\r\n\tbackground:#ffffff url(/img/zk_border_back.gif) repeat;\r\n}\r\n\r\n/*------------- menu -------------*/\r\n#wrapper .menu {\r\n\tfloat: left;\r\n\twidth: 157px;\r\n\theight: 234px;\r\n\tbackground: url(/img/zk_menu_back.gif) no-repeat;\r\n}\r\n\r\n#wrapper .menu ul {\r\n\tlist-style-type: none;\r\n}\r\n\r\n#menu ul li {\r\n}\r\n\r\n\r\n/*------------- contents -------------*/\r\n#wrapper .contents {\r\n  float:left;\r\n  width: 811px;\r\n  padding-left: 20px;\r\n  background:#ffffff;\r\n\tborder-right:1px #000000 solid;\r\n}\r\n  .timeout_message {\r\n    text-align: right;\r\n    font-weight: bold;\r\n    color: #F00;\r\n    width: 100%;\r\n  }\r\n\r\n  .contents td {\r\n    vertical-align: middle;\r\n  }\r\n\r\n  .contents td td {\r\n    vertical-align: top;\r\n  }\r\n\r\n#wrapper .contents_wide {\r\n  float:left;\r\n  width: 811px;\r\n  background:#ffffff;\r\n  border-right:1px #000000 solid;\r\n  padding-left:20px;\r\n  _padding-left:14px;\r\n}\r\n\r\n  .contents_wide .timeout_message {\r\n    text-align: right;\r\n    font-weight: bold;\r\n    color: #F00;\r\n    width: 100%;\r\n  }\r\n\r\n  .contents_wide td {\r\n      vertical-align: middle;\r\n  }\r\n\r\n#wrapper .contents_wide .frame_pane {\r\n  border-top: #000 1px solid;\r\n  border-bottom: #000 1px solid;\r\n  margin-left:-20px;\r\n  width: 830px;\r\n  _width: 837px;\r\n  height: 300px;\r\n  overflow: auto;\r\n  overflow-y: scroll;\r\n  text-align: left;\r\n}\r\n\r\n\r\n/*------------- footer -------------*/\r\n.copyright{\r\n\tclear: both;\r\n\ttext-align: right;\r\n\theight: 10px;\r\n\tpadding-top:10px;\r\n\tbackground:#ffffff;\r\n}\r\n#footer{\r\n\tclear: both;\r\n\ttext-align: right;\r\n\theight: 5px;\r\n\twidth: 989px;\r\n\tborder-left:1px #000000 solid;\r\n\tborder-bottom:1px #000000 solid;\r\n}\r\n\r\n\r\n/*------------- entry -------------*/\r\n.entry_table {\r\n\t/*\r\n    border-right: #aaaaaa 2px solid;\r\n    border-top: #aaaaaa 2px solid;\r\n    border-left: #aaaaaa 2px solid;\r\n    border-bottom: #aaaaaa 2px solid;\r\n    */\r\n}\r\n\r\n.entry_table .th_normal {\r\n  padding-left: 0px;\r\n  padding-right: 0px;\r\n  font-weight: normal;\r\n}\r\n\r\n.entry_table .entry_null {\r\n    height: 100px;\r\n    width: 125px;\r\n}\r\n\r\n.entry_table .entry_interest {\r\n    height: 100px;\r\n    width: 125px;\r\n}\r\n\r\n.entry_table .entry_other {\r\n    height: 100px;\r\n    width: 125px;\r\n}\r\n\r\n.entry_null {\r\n    border-right: #dddddd 1px solid;\r\n    border-top: #dddddd 1px solid;\r\n    border-left: #dddddd 1px solid;\r\n    border-bottom: #dddddd 1px solid;\r\n    background-color: #fff3c1;\r\n}\r\n.entry_interest {\r\n    border-right: #7a6f8c 1px solid;\r\n    border-top: #bface0 1px solid;\r\n    border-left: #bface0 1px solid;\r\n    border-bottom: #7a6f8c 1px solid;\r\n    background-color: #f3edff;\r\n}\r\n.entry_other {\r\n    border-right: #B1B3A6 1px solid;\r\n    border-top: #B3A6B3 1px solid;\r\n    border-left: #B3A6B3 1px solid;\r\n    border-bottom: #B1B3A6 1px solid;\r\n    background-color: #AAA6B3;\r\n}\r\n\r\n.timetable_table {\r\n    border:2px solid #AAAAAA;\r\n}\r\n\r\n  .timetable_table td{\r\n    padding-top: 0.3em;\r\n    padding-bottom: 0.3em;\r\n    padding-left: 0.5em;\r\n    padding-right: 0.5em;\r\n    font-weight: normal;\r\n  }\r\n\r\n#jsp_path {\r\n  display: none;\r\n}\r\n\r\n.notice_header_menu {\r\n\twidth: 770px;\r\n\tlist-style-type: none;\r\n\tmargin: 0px;\r\n\tpadding: 0px 0px 0px 0px;\r\n}\r\n\r\n.notice_header_menu li {\r\n\tfloat: left;\r\n\tdisplay: block;\r\n\twhite-space: nowrap;\r\n\tpadding: 0px 0px 5px 0px;\r\n}\r\n\r\n.timetable_null {\r\n  border-right: #dddddd 1px solid; border-top: #dddddd 1px solid; border-left: #dddddd 1px solid; border-bottom: #dddddd 1px solid; background-color: #fff3c1;\r\n  height: 100px;\r\n  width: 125px;\r\n}\r\n.timetable_filled {\r\n  border-right: #7a6f8c 1px solid; border-top: #bface0 1px solid; border-left: #bface0 1px solid; border-bottom: #7a6f8c 1px solid; background-color: #f3edff;\r\n  height: 100px;\r\n  width: 125px;\r\n}\r\n.timetable_reserved {\r\n  border-right: #658656 1px solid; border-top: #a3d08e 1px solid; border-left: #a3d08e 1px solid; border-bottom: #658656 1px solid; background-color: #e3ffc1;\r\n  height: 100px;\r\n  width: 125px;\r\n}\r\n.timetable_notice {\r\n  border-right: #ff0000 2px solid; border-top: #ff8b52 3px solid; border-left: #ff8b52 3px solid; border-bottom: #ff0000 3px solid; background-color: #f3edff;\r\n  height: 100px;\r\n  width: 125px;\r\n}\r\n\r\n.timetable_cap_exclude_lecture_tag {\r\n  color: white;\r\n  background: #FDBF2D;\r\n  display: inline;\r\n  padding: 3px;\r\n  border-radius: 8px 8px 8px 8px;\r\n}\r\n\r\n.timetable_intensive_reserved {\r\n  border-right: #658656 1px solid; border-top: #a3d08e 1px solid; border-left: #a3d08e 1px solid; border-bottom: #658656 1px solid; background-color: #e3ffc1;\r\n}\r\n\r\n.timetable_intensive_class {\r\n        border-left: #FFa880 2px solid;\r\n        padding-left: 1px;\r\n}\r\n.timetable_intensive_special {\r\n        border-left: #80b0e8 2px solid;\r\n        padding-left: 1px;\r\n}\r\n\r\n\r\n.mini_title {\r\n  font-size: 140%;\r\n  font-weight: bold;\r\n  color: #0000A0;\r\n}\r\n\r\n.after_margined {\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.indent2 {\r\n  padding-left: 2em;\r\n}\r\n\r\n\r\n.left {\r\n  text-align: left;\r\n}\r\n\r\n.center {\r\n  text-align: center;\r\n}\r\n\r\n.link_list td {\r\n  vertical-align: top;\r\n}\r\n\r\ntr.vertical_top td {\r\n  vertical-align: top;\r\n}\r\ntable.vertical_top tr td {\r\n  vertical-align: top;\r\n}\r\n\r\nli.input_form {\r\n  display: inline;\r\n}\r\n\r\n.validation_error {\r\n  border: red solid 2px;\r\n}\r\n\r\n.validation_error_message {\r\n  color: red;\r\n}\r\n\r\n.th_mark_list_title {\r\n    background-color: #9da0b4;\r\n\theight: 30px;\r\n\tcolor: white;\r\n\tfont-weight: bold;\r\n}\r\n\r\ninput.validation_error[type=\"text\"] {\r\n  border: red solid 2px;\r\n}\r\n\r\ntextbox.validation_error {\r\n  border: red solid 2px;\r\n}\r\n\r\n.validation_error_message {\r\n  color: red;\r\n}\r\n\r\n\r\n.blue_notice {\r\n  font-weight: bold;\r\n  color: #2863AB;\r\n  font-size: 0.8em;\r\n}\r\n\r\ntr.form_tab {\r\n  padding: 0px;\r\n  margin: 0px;\r\n}\r\n\r\ntr.form_tab td {\r\n  padding: 0px;\r\n  margin: 0px;\r\n}\r\n\r\ntr.form_tab td table {\r\n  padding: 0px;\r\n  margin: 0px;\r\n}\r\n\r\ntr.form_tab td table tbody {\r\n  padding: 0px;\r\n  margin: 0px;\r\n  offset: 0px;\r\n}\r\n\r\n.section_title {\r\n\tbackground-color: #797582;\r\n\tcolor: #ffffff;\r\n    font-weight: bold;\r\n}\r\n\r\n.li_checkboxes {\r\n  display: inline;\r\n}\r\n\r\n\r\n/*------------- PandA logo -------------*/\r\nimg.panda-logo {\r\n    padding: 1px;\r\n}\r\n\r\n/*------------- student/{la,base}/account/address* -------------*/\r\n.address_change_procedure .th_normal {\r\n  width: 300px;\r\n}\r\n\r\n.no_padding_tr td {\r\n  padding: 0 !important;\r\n}\r\n"
